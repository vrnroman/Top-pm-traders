# ═══════════════════════════════════════════════════════════════
# Poly Poly Bot — Unified Configuration
# Copy to .env and fill in values
# ═══════════════════════════════════════════════════════════════

# ── Strategy Toggles ──
STRATEGY1_ENABLED=false         # Copy Traders (TS bot)
STRATEGY2_ENABLED=true          # Weather Betting (Python)

# ── Strategy #2: Weather Betting ──
CITIES_TO_BET=nyc,chicago,denver,dallas
DAYS_IN_ADVANCE=4               # Bet on day T+4
MIN_EDGE=0.10                   # 10% minimum edge
BET_SIZE=10.0                   # USD per bet
MAX_BETS_PER_CITY=2             # Top 2 buckets per city

# ── Schedule ──
SCHEDULE_HOUR_SGT=15            # 3:00 PM Singapore Time
SCHEDULE_MINUTE_SGT=0

# ── Telegram ──
TELEGRAM_BOT_TOKEN=             # From @BotFather
TELEGRAM_CHAT_ID=               # Your chat ID

# ── Preview Mode ──
PREVIEW_MODE=true               # true = log only, false = place real bets

# ── Wallet (only needed when PREVIEW_MODE=false) ──
PRIVATE_KEY=
PROXY_WALLET=

# ── Strategy #1 Config (only if STRATEGY1_ENABLED=true) ──
# These are passed to the TS bot via its own .env in polymarket/
# USER_ADDRESSES=0xabc...,0xdef...
# COPY_STRATEGY=PERCENTAGE
# COPY_SIZE=10.0
# MAX_ORDER_SIZE_USD=100
# MAX_DAILY_VOLUME_USD=1000

# ── Strategy #3: Tennis Odds Arbitrage ──
STRATEGY3_ENABLED=false         # Tennis Arb (Pinnacle vs Polymarket)
TENNIS_ARB_PREVIEW_MODE=true    # true = log only, false = place real bets
TENNIS_ODDS_PROVIDER=oddspapi   # oddspapi | scraper
ODDSPAPI_API_KEY=               # Free tier key from oddspapi.io (250 req/month)
TENNIS_MIN_DIVERGENCE=0.10      # Minimum edge to trigger (10%)
TENNIS_MAX_BET_SIZE=100         # Max USD per bet
TENNIS_KELLY_FRACTION=0.25      # Fraction of Kelly criterion for sizing
TENNIS_SCAN_INTERVAL=300        # Seconds between scans (5 min)
TENNIS_TOURNAMENTS=ATP,WTA      # Which tours to monitor
TENNIS_MIN_POLYMARKET_VOLUME=50000   # Minimum market volume to consider
TENNIS_MIN_POLYMARKET_LIQUIDITY=10000 # Minimum liquidity to consider

# ── GCP Deployment ──
GCP_PROJECT_ID=roman-vm
