# ==============================================================================
# POLYMARKET COPY TRADING BOT
# ==============================================================================

# Trader wallets to copy (comma-separated)
# Example: 0xabc...,0xdef...,0x123...
USER_ADDRESSES=

# Your Polygon wallet address
PROXY_WALLET=

# Your wallet private key (WITHOUT 0x prefix)
# WARNING: Never share or commit this!
PRIVATE_KEY=

# Signature type: only 0 (EOA/MetaMask) is currently supported
SIGNATURE_TYPE=0

# ------------------------------------------------------------------------------
# COPY STRATEGY
# ------------------------------------------------------------------------------
# PERCENTAGE = copy X% of trader's order size
# FIXED = copy fixed USD amount per trade
COPY_STRATEGY=PERCENTAGE

# For PERCENTAGE: e.g. 10.0 = 10% of trader's order
# For FIXED: e.g. 25.0 = $25 per trade
COPY_SIZE=10.0

# ------------------------------------------------------------------------------
# RISK LIMITS
# ------------------------------------------------------------------------------
MAX_ORDER_SIZE_USD=100.0
MIN_ORDER_SIZE_USD=1.0

# Max USD placed on a single market per day (resets at midnight UTC)
MAX_POSITION_PER_MARKET_USD=500.0

# Max total trading volume per day (resets at midnight UTC)
MAX_DAILY_VOLUME_USD=1000.0

# Max times we will copy the exact same bet (same trader, market, outcome)
MAX_COPIES_PER_MARKET_SIDE=2


# ------------------------------------------------------------------------------
# BOT SETTINGS
# ------------------------------------------------------------------------------
# Poll interval in seconds
FETCH_INTERVAL=1

# Max concurrent trader fetches per batch (default 5)
FETCH_CONCURRENCY=5

# Ignore trades older than X hours
MAX_TRADE_AGE_HOURS=1

# Max acceptable price drift from trader's entry in basis points (300 = 3%)
# Trades where market moved beyond this threshold are skipped
MAX_PRICE_DRIFT_BPS=300

# Max acceptable bid-ask spread in basis points (500 = 5%)
# Trades in illiquid markets with wider spreads are skipped
MAX_SPREAD_BPS=500

# Trade monitor mode: data-api (default), hybrid (data-api + on-chain), onchain (RPC only)
TRADE_MONITOR_MODE=data-api

# Preview mode: true = log trades but don't execute
PREVIEW_MODE=true

# Auto-redeem interval for settled markets (hours)
REDEEM_INTERVAL_HOURS=0.5

# ------------------------------------------------------------------------------
# API ENDPOINTS (defaults are fine for production)
# ------------------------------------------------------------------------------
CLOB_API_URL=https://clob.polymarket.com
DATA_API_URL=https://data-api.polymarket.com
RPC_URL=https://polygon-rpc.com

# Log format: "text" (human-readable with colors) or "json" (structured for ops)
LOG_FORMAT=text

# ------------------------------------------------------------------------------
# TELEGRAM NOTIFICATIONS (optional)
# ------------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ------------------------------------------------------------------------------
# GCP DEPLOYMENT (used by deploy.sh)
# ------------------------------------------------------------------------------
GCP_PROJECT_ID=poly-bot-reks
