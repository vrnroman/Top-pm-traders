# ═══════════════════════════════════════════════════════════════
# Weather Bot — Unified Configuration
# Copy to .env and fill in values
# ═══════════════════════════════════════════════════════════════

# ── Strategy Toggles ──
STRATEGY1_ENABLED=false         # Copy Traders (TS bot)
STRATEGY2_ENABLED=true          # Weather Betting (Python)

# ── Strategy #2: Weather Betting ──
CITIES_TO_BET=nyc,chicago,denver,dallas
DAYS_IN_ADVANCE=4               # Bet on day T+4
MIN_EDGE=0.10                   # 10% minimum edge
BET_SIZE=10.0                   # USD per bet
MAX_BETS_PER_CITY=2             # Top 2 buckets per city

# ── Schedule ──
SCHEDULE_HOUR_SGT=15            # 3:00 PM Singapore Time
SCHEDULE_MINUTE_SGT=0

# ── Telegram ──
TELEGRAM_BOT_TOKEN=             # From @BotFather
TELEGRAM_CHAT_ID=               # Your chat ID

# ── Preview Mode ──
PREVIEW_MODE=true               # true = log only, false = place real bets

# ── Wallet (only needed when PREVIEW_MODE=false) ──
PRIVATE_KEY=
PROXY_WALLET=

# ── Strategy #1 Config (only if STRATEGY1_ENABLED=true) ──
# These are passed to the TS bot via its own .env in polymarket/
# USER_ADDRESSES=0xabc...,0xdef...
# COPY_STRATEGY=PERCENTAGE
# COPY_SIZE=10.0
# MAX_ORDER_SIZE_USD=100
# MAX_DAILY_VOLUME_USD=1000

# ── GCP Deployment ──
GCP_PROJECT_ID=roman-vm
